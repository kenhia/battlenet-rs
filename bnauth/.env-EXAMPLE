# Required — app will fail fast if missing
BATTLENET_CLIENT_ID=your_client_id_here
BATTLENET_CLIENT_SECRET=your_client_secret_here
FLASK_SECRET_KEY=generate_a_random_secret_key
REDISCLI_AUTH=your_redis_password_here

# Optional — defaults shown
BATTLENET_REGION=us
BNAUTH_REDIS_HOST=rpi53
BNAUTH_REDIS_PORT=6379
BNAUTH_FLASK_PORT=5050
# Use 127.0.0.1 (not localhost) — Windows resolves localhost to IPv6 ::1
# which Flask does not listen on. Must match the redirect URI registered
# in the Blizzard Developer Portal.
BNAUTH_CALLBACK_HOST=127.0.0.1
